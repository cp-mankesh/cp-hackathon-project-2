# Database (SQLite — no Docker required)
DATABASE_URL="file:../../../data/ados.db"

# Temporal (embedded dev server via npm — no Docker required)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ados-ticket-queue

# API
API_PORT=4020
API_URL=http://localhost:4020
WEB_PORT=3020
WEB_URL=http://localhost:3020
SESSION_SECRET=change-me-to-a-long-random-string

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4020/api/auth/github/callback

# Jira OAuth (optional)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_CALLBACK_URL=http://localhost:4020/api/auth/jira/callback

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Agent limits
AGENT_MAX_RETRIES=3
AGENT_MAX_REVIEW_ROUNDS=2
WORKSPACES_DIR=./data/workspaces

# Encryption key for stored tokens (32 bytes hex)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Database
DATABASE_URL=postgresql://ados:ados_secret@localhost:5433/ados

# Redis
REDIS_URL=redis://localhost:6380

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ados-ticket-queue

# API
API_PORT=4020
API_URL=http://localhost:4020
WEB_PORT=3020
WEB_URL=http://localhost:3020
SESSION_SECRET=change-me-to-a-long-random-string

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4020/api/auth/github/callback

# Jira OAuth (optional)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_CALLBACK_URL=http://localhost:4020/api/auth/jira/callback

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Agent limits
AGENT_MAX_RETRIES=3
AGENT_MAX_REVIEW_ROUNDS=2
WORKSPACES_DIR=/tmp/ados-workspaces

# Encryption key for stored tokens (32 bytes hex)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
